PORT=3001
NODE_NAME=node-1
CLIENT_ORIGINS=http://localhost:5173,http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=dsh.sid
SESSION_TTL_MS=1800000
REDIS_URL=redis://localhost:6379
REDIS_SESSION_PREFIX=dsh:sess:
TRUST_PROXY=false
COOKIE_SECURE=false

LOAD_BALANCER_PORT=3000
BACKEND_TARGETS=http://localhost:3001,http://localhost:3002,http://localhost:3003
STICKY_SESSIONS=false
STICKY_COOKIE_NAME=dsh.lb
STICKY_COOKIE_TTL_SEC=1800
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL_MS=5000
HEALTH_CHECK_TIMEOUT_MS=1500
PROXY_TIMEOUT_MS=8000
PROXY_RETRY_COUNT=1
ALERT_MIN_SAMPLES=20
ALERT_ERROR_RATE_THRESHOLD=0.2
ALERT_RETRY_RATE_THRESHOLD=0.3
ALERT_AVG_LATENCY_MS_THRESHOLD=500
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=4000
ALERT_NOTIFICATION_COOLDOWN_SEC=120
INCIDENT_HISTORY_LIMIT=100
REMEDIATION_ENABLED=true
AUTO_DRAIN_FAILURE_THRESHOLD=3
AUTO_DRAIN_COOLDOWN_SEC=90
REMEDIATION_HISTORY_LIMIT=100
ESCALATION_ENABLED=true
ESCALATION_COOLDOWN_SEC=180
ESCALATION_HISTORY_LIMIT=100
ESCALATION_AUTO_RESOLVE_ON_RECOVERY=true
ESCALATION_ON_DRAINED_TARGETS=true
ESCALATION_RESPONSE_SLA_SEC=120
ESCALATION_RESOLUTION_SLA_SEC=600
ESCALATION_SLA_BREACH_COOLDOWN_SEC=120
